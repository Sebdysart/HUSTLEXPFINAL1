# SECTION 2: WHAT YOU MAY DO
# ══════════════════════════════════════════════════════════════════════════════

# ALLOWED ACTIONS:
# ✅ Implement screens listed in screens-spec/SCREEN_REGISTRY.md
# ✅ Use atoms from src/components/atoms/
# ✅ Use molecules from src/components/molecules/
# ✅ Use constants from reference/constants/
# ✅ Create TypeScript interfaces for props
# ✅ Assemble screens from existing pieces

# ══════════════════════════════════════════════════════════════════════════════
# SECTION 3: WHAT YOU MAY NOT DO (HARD PROHIBITIONS)
# ══════════════════════════════════════════════════════════════════════════════

# FORBIDDEN — VIOLATING THESE IS A BUILD FAILURE:

# ❌ FORBIDDEN: Invent new visual components at the Screen level
# ❌ FORBIDDEN: Create inline styled components (must use atoms/molecules)
# ❌ FORBIDDEN: Duplicate molecules with minor variations
# ❌ FORBIDDEN: Treat screens as unique design problems
# ❌ FORBIDDEN: Define new screens not in SCREEN_REGISTRY.md
# ❌ FORBIDDEN: Add npm dependencies without explicit user approval
# ❌ FORBIDDEN: Modify navigation structure
# ❌ FORBIDDEN: Invent backend API fields or endpoints
# ❌ FORBIDDEN: Compute business logic (eligibility, XP, trust, pricing)
# ❌ FORBIDDEN: Make fetch/API calls (parent components handle this)
# ❌ FORBIDDEN: Use Redux, Context, or global state for data
# ❌ FORBIDDEN: Create mock data that implies backend behavior
# ❌ FORBIDDEN: "Improve" or "enhance" specs — implement EXACTLY as written

# ══════════════════════════════════════════════════════════════════════════════
# SECTION 4: THE SCREEN CONTRACT
# ══════════════════════════════════════════════════════════════════════════════

# Every screen you build MUST follow this pattern:

# 1. Props interface (data comes from parent, you never fetch)
# 2. Loading state (shown when isLoading=true)
# 3. Empty state (shown when primary data is missing — but feel CHOSEN)
# 4. Content state (assembled from atoms/molecules, nothing invented)
# 5. Actions (onPress callbacks passed as props, no logic inside)

# TEMPLATE:
# ```tsx
# interface ScreenNameProps {
#   data?: DataType;
#   isLoading?: boolean;
#   onAction?: () => void;
# }
#
# export function ScreenName({ data, isLoading, onAction }: ScreenNameProps) {
#   if (isLoading) return <LoadingState />; // User feels active, not waiting
#   if (!data) return <EmptyState />;       // User feels chosen, not lacking
#   return <Content data={data} onAction={onAction} />;
# }
# ```

# ══════════════════════════════════════════════════════════════════════════════
# SECTION 5: PROHIBITED CODE PATTERNS
# ══════════════════════════════════════════════════════════════════════════════

# IF YOU WRITE ANY OF THESE, YOU HAVE FAILED:

# ❌ const isEligible = user.trustTier >= task.requiredTier;
#    WHY: Client-side eligibility computation

# ❌ const xpAmount = calculateXP(task);
#    WHY: Client-side business logic

# ❌ <View style={{ backgroundColor: '#custom' }}>
#    WHY: Inline styles instead of using atoms/design tokens

# ❌ <CustomCardThatDoesntExist />
#    WHY: Inventing components at screen level

# ❌ fetch('/api/...')
#    WHY: Screens don't fetch. Parent components do.

# ❌ "No tasks yet" or "Get started by..."
#    WHY: Makes user feel like starting from zero (violates chosen-state)

# ══════════════════════════════════════════════════════════════════════════════
# SECTION 6: WHEN TO STOP AND ASK
# ══════════════════════════════════════════════════════════════════════════════

# STOP IMMEDIATELY AND ASK THE USER IF:

# 🛑 You can't identify the screen's archetype
# 🛑 The atom or molecule you need doesn't exist
# 🛑 The screen is not in SCREEN_REGISTRY.md
# 🛑 You need a data field not defined in the props interface
# 🛑 You need to add a dependency
# 🛑 The spec is unclear or seems incomplete
# 🛑 You think the spec is wrong
# 🛑 You want to "improve" something

# DO NOT GUESS. DO NOT ASSUME. DO NOT "HELP" BY FILLING GAPS.

# ══════════════════════════════════════════════════════════════════════════════
