<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  TestFlight / App Store export options for HustleXP — MANUAL signing.
  CI imports an Apple Distribution cert (.p12) + the "HustleXP App Store CI"
  provisioning profile, then exports with destination=upload so xcodebuild
  uploads straight to TestFlight (authenticated by the App Store Connect API key).
  TEAM_ID_PLACEHOLDER is replaced from the APPLE_TEAM_ID secret at build time.
-->
<plist version="1.0">
<dict>
    <key>method</key>
    <string>app-store</string>
    <key>teamID</key>
    <string>TEAM_ID_PLACEHOLDER</string>
    <key>destination</key>
    <string>upload</string>
    <key>signingStyle</key>
    <string>manual</string>
    <key>signingCertificate</key>
    <string>Apple Distribution</string>
    <key>provisioningProfiles</key>
    <dict>
        <key>taskme.hustleXP-final1</key>
        <string>HustleXP App Store CI</string>
    </dict>
    <key>manageAppVersionAndBuildNumber</key>
    <true/>
    <key>uploadSymbols</key>
    <true/>
    <key>uploadBitcode</key>
    <false/>
    <key>compileBitcode</key>
    <false/>
    <key>stripSwiftSymbols</key>
    <true/>
</dict>
</plist>
