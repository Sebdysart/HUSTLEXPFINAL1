# HustleXP Web — environment configuration
# Copy to .env.local and fill in. NEXT_PUBLIC_* are exposed to the browser.

# Backend tRPC API (staging or prod). No trailing slash.
NEXT_PUBLIC_API_URL=https://api.hustlexp.com

# Firebase Web SDK (same Firebase project as the iOS app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Stripe (publishable key only — never the secret key in web)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# PostHog (pre-auth funnel analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
